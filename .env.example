# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose to the browser — Row Level Security protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose this publicly. Server-side only (Stripe webhook).
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys

ANTHROPIC_API_KEY=sk-ant-...


# ─── Stripe ──────────────────────────────────────────────────────────────────
# Found in: dashboard.stripe.com → Developers → API Keys

# Publishable key — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Secret key — NEVER expose this publicly. Server-side only.
STRIPE_SECRET_KEY=sk_live_...

# The Price ID of your Pro plan ($9/month recurring price)
# Found in: Stripe Dashboard → Products → your Pro product → Price ID
STRIPE_PRO_PRICE_ID=price_...

# Webhook signing secret — obtained when you register the webhook endpoint in Stripe
# Development: use `stripe listen` CLI secret (whsec_...)
# Production: use the secret from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
